{
  "name": "shapes-of-stories-keynote",
  "version": "2.0.0",
  "description": "Motion-graphics keynote for the Shapes of Stories thesis. Mirrors the live website's palette, typography, and arc-rendering math.",
  "scripts": {
    "dev": "remotion studio src/index.ts",
    "render": "remotion render src/index.ts Keynote out/keynote.mp4 --concurrency=4",
    "render:hq": "remotion render src/index.ts Keynote out/keynote-hq.mp4 --concurrency=4 --crf=16"
  },
  "dependencies": {
    "@remotion/bundler": "4.0.250",
    "@remotion/cli": "4.0.250",
    "@remotion/google-fonts": "4.0.250",
    "@remotion/renderer": "4.0.250",
    "@types/d3-array": "^3.2.2",
    "@types/d3-dsv": "^3.0.7",
    "@types/d3-force": "^3.0.10",
    "d3-array": "^3.2.4",
    "d3-dsv": "^3.0.1",
    "d3-force": "^3.0.0",
    "d3-scale": "^4.0.2",
    "d3-shape": "^3.2.0",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "remotion": "4.0.250"
  },
  "devDependencies": {
    "@types/d3-scale": "^4.0.8",
    "@types/d3-shape": "^3.1.6",
    "@types/react": "19.0.1",
    "@types/react-dom": "19.0.1",
    "typescript": "5.7.2"
  }
}
